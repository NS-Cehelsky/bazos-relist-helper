{
  "manifest_version": 3,
  "name": "Bazoš Re-List Helper",
  "version": "1.0.0",
  "description": "Ulož si inzerát na bazos.sk jedným klikom a neskôr ho rýchlo znova vlož do formulára. Lokálne, bez servera a AI.",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "*://*.bazos.sk/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Bazoš Re-List Helper"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.bazos.sk/*"],
      "exclude_matches": ["*://*.bazos.sk/pridat-inzerat.php*"],
      "js": ["content-scripts/capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.bazos.sk/pridat-inzerat.php*"],
      "js": ["content-scripts/prefill.js"],
      "run_at": "document_idle"
    }
  ]
}
